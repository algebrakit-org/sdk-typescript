# Algebrakit API Configuration
# Copy this file to .env and add your API key

# Your Algebrakit API key
ALGEBRAKIT_API_KEY=your_api_key_here

# API Base URL (optional, defaults to production)
ALGEBRAKIT_API_URL=https://api.algebrakit.com

# Widget script URL (optional, defaults to production)
ALGEBRAKIT_WIDGET_URL=https://widgets.algebrakit.com

# Port for the local server
PORT=3000